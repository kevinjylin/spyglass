{
  "name": "spyglass-extension",
  "displayName": "SpyGlass Extension",
  "version": "0.1.0",
  "description": "Inline fact-check badges on X / Twitter, powered by Gemini.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.5"
  },
  "manifest": {
    "name": "SpyGlass Extension",
    "description": "Inline fact-check badges on X / Twitter, powered by Gemini.",
    "permissions": ["storage"],
    "host_permissions": [
      "https://twitter.com/*",
      "https://x.com/*",
      "http://localhost:8000/*"
    ]
  }
}
